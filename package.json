{
  "name": "openclaw-agent-sandbox-backend",
  "version": "0.1.0",
  "description": "OpenClaw sandbox backend that runs agent terminal/exec inside gVisor agent-sandbox (Kubernetes) Pods via in-cluster pods/exec.",
  "license": "MIT",
  "type": "module",
  "repository": { "type": "git", "url": "https://github.com/vol1003/openclaw-agent-sandbox-backend" },
  "files": ["dist", "index.ts", "src", "openclaw.plugin.json", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.0.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.6.10"
  },
  "devDependencies": {
    "openclaw": "2026.6.10",
    "@types/node": "^22.0.0",
    "typescript": "^5.9.0",
    "vitest": "^2.0.0"
  },
  "engines": { "node": ">=20" },
  "openclaw": {
    "extensions": ["./dist/index.js"],
    "install": {
      "npmSpec": "openclaw-agent-sandbox-backend",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.6.10"
    },
    "compat": { "pluginApi": ">=2026.6.10" },
    "build": { "openclawVersion": "2026.6.10", "bundledDist": true }
  }
}
